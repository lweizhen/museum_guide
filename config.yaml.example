# ==============================================
# Museum Guide - configuration example
# ==============================================
# Usage:
# 1. Copy this file to config.yaml.
# 2. Fill in your own API key if you use DashScope.
# 3. Do not commit config.yaml, because it may contain secrets.
# ==============================================

# Available values: "ollama" or "dashscope"
llm_provider: "ollama"

dashscope:
  api_key: "YOUR_DASHSCOPE_API_KEY"
  model: "qwen3.5-plus"
  multimodal_model: "qwen-vl-plus"
  temperature: 0.3

ollama:
  base_url: "http://localhost:11434"
  model: "qwen2.5:7b"
  multimodal_model: "qwen2.5vl:7b"
  temperature: 0.3
  timeout_seconds: 600

embedding:
  model_name: "paraphrase-multilingual-MiniLM-L12-v2"

data_path: "data/exhibits_combined.txt"
index_path: "index/exhibits.index"

image_index:
  csv_path: "bowuguozhongguo_names_filtered.csv"
  image_cache_dir: "data/museumschina_images"
  index_path: "index/exhibits_images.index"
  meta_path: "index/exhibits_images_meta.json"
  model_name: "clip-ViT-B-32"
  top_k: 5
  min_score: 0.55
  min_gap: 0.03
  max_images_per_item: 3

retrieval:
  top_k: 5
  threshold: 0.5
  margin: 0.15

tts:
  voice: "zh-CN-XiaoxiaoNeural"
  output_dir: "outputs/media"
